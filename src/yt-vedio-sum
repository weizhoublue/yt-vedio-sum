#!/usr/bin/env bash
# YouTube 视频转录工具 Shell 入口
# 将参数传递给 Python CLI

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 检查 Python 环境
if ! command -v python3 &> /dev/null; then
    echo "❌ 错误: 未找到 python3，请安装 Python 3.10+"
    exit 1
fi

# 检查 Python 依赖（通过检查模块是否存在）
if ! python3 -c "import yt_utils" 2>/dev/null; then
    echo "⚠️  首次运行，正在检查 Python 依赖..."
    echo "请确保已安装依赖: pip install -r requirements.txt"
fi

# 调用 Python CLI
exec python3 "$SCRIPT_DIR/yt_cli.py" "$@"